# Copia questo file in ".env" e incolla i valori del tuo progetto Supabase.
# Li trovi in: Supabase → Project Settings → API
# (la anon key è pubblica per definizione: è sicuro esporla nel frontend.)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...la-tua-anon-public-key...
